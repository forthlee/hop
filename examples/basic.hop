pi = 3.14159265358979;
n = 10;

pi;
n;
pi * n;

write "Hello world\n";

fun abs(x) = if x < 0 then -x else x;

abs(-7);
abs(3);

fun max(a, b) = if a > b then a else b;

max(3, 7);
max(10, 5);

fun gcd(a, 0) = a;
--- gcd(a, b) = gcd(b, a mod b);

gcd(12, 8);
gcd(100, 75);

fun even(n) = if n mod 2 == 0 then 1 else 0;

even(4);
even(7);

fun fact(0) = 1;
--- fact(n) = n * fact(n - 1);

fact(10);
